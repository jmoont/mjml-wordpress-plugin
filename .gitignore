# This repo lives inside a WordPress Studio site, but it only tracks the
# MJML Email Builder plugin plus the project/agent working files. Everything
# else (WordPress core, default themes, the SQLite integration, uploads, …)
# is managed by Studio and deliberately ignored.

# ── Ignore everything at the repo root by default ──────────────────────────
/*

# ── …then re-include just the project files we care about ──────────────────
!/.gitignore
!/.claude/
!/AGENTS.md
!/CLAUDE.md
!/STUDIO.md
!/mjml-email-builder.zip

# Claude's transient worktrees and machine-local settings are never tracked,
# even though .claude/ otherwise is.
/.claude/worktrees/
/.claude/settings.local.json

# ── Descend into wp-content for the custom plugin only ─────────────────────
!/wp-content/
/wp-content/*
!/wp-content/plugins/
/wp-content/plugins/*
!/wp-content/plugins/mjml-email-builder/

# ── OS / editor noise ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
